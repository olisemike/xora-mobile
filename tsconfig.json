{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "jsx": "react",
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": [
      "ES2020",
      "DOM",
    ],
    "ignoreDeprecations": "6.0",
  },
  "include": [
    "App.js",
    "src/**/*",
  ],
  "exclude": [
    "node_modules",
    "android/build",
    "android/app/build",
  ],
  "extends": "expo/tsconfig.base",
}
