# ============================================
# Xora Social - Mobile App Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git!
# ============================================

# ============================================
# API Configuration
# ============================================
# For local testing with wrangler dev:
# Get your computer's LAN IP: Run 'ipconfig' on Windows and look for "IPv4 Address"
# Replace 192.168.x.x with YOUR actual IP address
EXPO_PUBLIC_API_URL=http://192.168.x.x:8787

# For production deployment:
# EXPO_PUBLIC_API_URL=https://your-api-url.workers.dev

# ============================================
# reCAPTCHA Configuration
# ============================================
# Get your site key from: https://www.google.com/recaptcha/admin
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=6LdjiEQsAAAAACy0Yrtr_AVvJTFZQFTjnRFpHxY1

# ============================================
# App Configuration
# ============================================
EXPO_PUBLIC_APP_NAME=Xora Social
EXPO_PUBLIC_APP_VERSION=1.0.0
EXPO_PUBLIC_EXPO_PROJECT_ID=your-expo-project-id

# ============================================
# Cloudflare Media Configuration
# ============================================
# Get these from your Cloudflare dashboard > Images/Stream settings
EXPO_PUBLIC_CLOUDFLARE_IMAGES_HASH=your-cloudflare-images-hash
EXPO_PUBLIC_CLOUDFLARE_STREAM_SUBDOMAIN=customer-xxxxx.cloudflarestream.com

# ============================================
# Feature Flags
# ============================================
EXPO_PUBLIC_ENABLE_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_2FA=true
EXPO_PUBLIC_ENABLE_DEVICE_VERIFICATION=true

# ============================================
# Error Tracking (Sentry)
# ============================================
# Get your DSN from https://sentry.io/settings/projects/your-project/keys/
# Leave empty for development, set for production
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn-here
